{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "outDir": "./public/dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "rootDir": "./src"
  },
  "include": [
    "src/**/*.ts"
  ]
}
